<?xml version="1.0" encoding="UTF-8"?>
<!--
  EXEMPLO 01 — Anatomia de um Ficheiro NeTEx
  ==========================================
  Curso: NeTEx PT Formação — Módulo 1: Conceitos Base
  Fonte dos dados: STCP (Sociedade de Transportes Colectivos do Porto) [DATA-03]
  Perfil: NeTEx Portugal (PT-EPIP) [PT-01]

  O que este ficheiro demonstra:
  - A estrutura raiz PublicationDelivery (o "envelope" de todo o ficheiro NeTEx)
  - O CompositeFrame como contentor de múltiplos frames
  - O ResourceFrame com Authority (IMT) e Operator (STCP)
  - O ServiceFrame com a definição mínima da Linha 200
  - O formato correcto de identificadores NeTEx para Portugal
  - O uso de validBetween para controlo de validade

  Referências:
  - [STD-01] CEN/TS 16614-1:2024 (NeTEx Parte 1 — Topologia de Rede)
  - [STD-04] CEN EN 12896 (Transmodel)
  - [PT-01]  IMT. Perfil Nacional NeTEx Portugal
  - [DATA-03] STCP. Feed GTFS Porto, versão Escolar 228 (2026-04-30)
-->

<!--
  PublicationDelivery é o elemento raiz de QUALQUER ficheiro NeTEx.
  Serve de "envelope" que identifica quem publicou os dados, quando,
  e qual a versão do schema usada.

  xmlns: declara o namespace NeTEx — necessário para validação XSD.
-->
<PublicationDelivery
    xmlns="http://www.netex.org.uk/netex"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.netex.org.uk/netex NeTEx_publication.xsd"
    version="1.0">

  <!--
    PublicationTimestamp: quando este ficheiro foi gerado (ISO 8601).
    Importante para rastreabilidade e para o NAP saber qual é o ficheiro mais recente.
  -->
  <PublicationTimestamp>2026-04-30T00:00:00Z</PublicationTimestamp>

  <!--
    ParticipantRef: identifica a organização que publicou estes dados.
    Formato: PT:<código da organização>
    A STCP usa "STCP" como código de participante.
  -->
  <ParticipantRef>PT:STCP</ParticipantRef>

  <!--
    dataObjects: contentor de todos os frames de dados.
    Pode conter um ou mais CompositeFrame / frames individuais.
  -->
  <dataObjects>

    <!--
      CompositeFrame: agrupa múltiplos frames sob um identificador e período de validade comuns.
      É o contentor de nível mais alto — pense nele como um "pacote de dados" coerente.

      id: formato = <país>:<operador>:<Tipo>:<identificadorLocal>:<âmbito>
        - PT     = Portugal (código ISO 3166-1)
        - STCP   = operador (código STCP)
        - CompositeFrame = tipo de objecto
        - STCP_L200_2026 = identificador local (linha 200, versão 2026)
        - LOC    = âmbito local (válido em Portugal)

      version: número inteiro incremental. Começa em 1.
    -->
    <CompositeFrame id="PT:STCP:CompositeFrame:STCP_L200_2026:LOC" version="1">

      <!--
        validBetween: período de validade de todos os dados dentro deste frame.
        FromDate: início da validade (quando o horário começa a vigorar)
        Sem ToDate: válido indefinidamente até ser substituído por nova versão.
      -->
      <validBetween>
        <FromDate>2026-04-30</FromDate>
      </validBetween>

      <!--
        TypeOfFrameRef: referência ao tipo de CompositeFrame.
        "EU_PI_COMMON" é um tipo standard europeu para dados de transporte público.
        Pode variar conforme o perfil nacional.
      -->
      <TypeOfFrameRef ref="epip:EU_PI_COMMON"/>

      <frames>

        <!--
          =========================================================
          RESOURCE FRAME
          =========================================================
          Contém os recursos organizacionais: quem gere, quem opera.
          Equivalente GTFS aproximado: agency.txt
          Mas muito mais rico — distingue Authority de Operator.
        -->
        <ResourceFrame id="PT:STCP:ResourceFrame:STCP_RF_2026:LOC" version="1">

          <!--
            organisations: lista de entidades organizacionais.
            NeTEx distingue:
            - Authority: entidade com poder regulatório (ex: IMT, CM Porto)
            - Operator: entidade que opera o serviço (ex: STCP, Metro do Porto)

            No GTFS, agency.txt mistura os dois papéis.
            No NeTEx, são objetos distintos — uma linha pode ter uma Authority
            diferente do seu Operator.
          -->
          <organisations>

            <!--
              Authority: entidade reguladora / autoridade de transporte.
              O IMT (Instituto da Mobilidade e dos Transportes) é a autoridade
              nacional de transporte em Portugal.

              Aqui aparece porque os dados são submetidos ao NAP gerido pelo IMT.
            -->
            <Authority id="PT:IMT:Authority:IMT:LOC" version="1">
              <Name>Instituto da Mobilidade e dos Transportes</Name>
              <ShortName>IMT</ShortName>
              <ContactDetails>
                <Url>https://www.imt-ip.pt</Url>
              </ContactDetails>
            </Authority>

            <!--
              Operator: entidade que opera o serviço de transporte.
              A STCP opera os autocarros do Porto.

              PublicCode: código público reconhecível pelos utilizadores.
              Url: website oficial da STCP (= agency_url no GTFS).
              Phone: número de contacto (= agency_phone no GTFS).

              Correspondência GTFS:
                agency_id   → id do Operator (PT:STCP:Operator:STCP:LOC)
                agency_name → Name
                agency_url  → ContactDetails/Url
                agency_phone → ContactDetails/Phone
                agency_lang → (implícito pelo país PT)
                agency_timezone → (definido ao nível do ServiceFrame)
            -->
            <Operator id="PT:STCP:Operator:STCP:LOC" version="1">
              <Name>Sociedade de Transportes Colectivos do Porto, E.I.M., S.A.</Name>
              <ShortName>STCP</ShortName>
              <PublicCode>STCP</PublicCode>
              <ContactDetails>
                <Url>https://www.stcp.pt</Url>
                <Phone>225071000</Phone>
              </ContactDetails>
              <CustomerServiceContactDetails>
                <Email>clientes@stcp.pt</Email>
              </CustomerServiceContactDetails>
            </Operator>

          </organisations>
        </ResourceFrame>

        <!--
          =========================================================
          SERVICE FRAME
          =========================================================
          Contém a rede lógica de transporte:
          - Network (agrupamento de linhas)
          - Lines (linhas comerciais)
          - Routes (sequências de pontos por direção)
          - ScheduledStopPoints (pontos lógicos de paragem)

          Módulo 2 irá aprofundar todos estes elementos.
          Aqui mostramos apenas a estrutura mínima para demonstrar o conceito.

          Equivalente GTFS aproximado: routes.txt + stops.txt (parcial)
        -->
        <ServiceFrame id="PT:STCP:ServiceFrame:STCP_SF_2026:LOC" version="1">

          <!--
            Network: agrupa linhas sob uma marca/rede comum.
            A STCP opera uma única rede de autocarros urbanos do Porto.

            Equivalente GTFS: não existe directamente. O agency_id
            é o mais próximo, mas não modela a rede como entidade própria.
          -->
          <Network id="PT:STCP:Network:STCP_Porto:LOC" version="1">
            <Name>Rede de Autocarros STCP — Porto</Name>
            <ShortName>STCP</ShortName>
            <OperatorRef ref="PT:STCP:Operator:STCP:LOC" version="1"/>
          </Network>

          <lines>
            <!--
              Line: a linha comercial, tal como é conhecida pelos passageiros.
              A Linha 200 liga o Bolhão ao Castelo do Queijo.

              Distinção fundamental NeTEx vs GTFS:
              - Em GTFS, "route" mistura a identidade comercial (nome, cor) com a topologia
              - Em NeTEx, Line é APENAS a identidade comercial
                A topologia (sequência de paragens) vive na Route (ver Módulo 2)

              PublicCode: o número da linha como aparece nos autocarros e paragens.
              TransportMode: "bus" = autocarro (equivalente a route_type=3 no GTFS).

              Correspondência GTFS routes.txt:
                route_id         → id (PT:STCP:Line:200:LOC)
                route_short_name → PublicCode ("200")
                route_long_name  → Name ("Bolhão — Castelo do Queijo")
                route_type       → TransportMode ("bus")
                route_color      → Presentation/Colour
                route_text_color → Presentation/TextColour
                agency_id        → OperatorRef
            -->
            <Line id="PT:STCP:Line:200:LOC" version="1">
              <Name>Bolhão — Castelo do Queijo</Name>
              <ShortName>200</ShortName>
              <PublicCode>200</PublicCode>
              <TransportMode>bus</TransportMode>
              <TransportSubmode>
                <BusSubmode>localBus</BusSubmode>
              </TransportSubmode>
              <Presentation>
                <!--
                  Presentation: informação visual da linha.
                  Dados retirados do feed GTFS: route_color=187EC2, route_text_color=FFFFFF
                -->
                <Colour>187EC2</Colour>
                <TextColour>FFFFFF</TextColour>
              </Presentation>
              <OperatorRef ref="PT:STCP:Operator:STCP:LOC" version="1"/>
              <NetworkRef ref="PT:STCP:Network:STCP_Porto:LOC" version="1"/>
              <Url>https://www.stcp.pt/pt/viajar/linhas/?linha=200</Url>
            </Line>

          </lines>

          <!--
            scheduledStopPoints: lista de pontos lógicos de paragem.

            ScheduledStopPoint = onde o veículo para e os passageiros embarcam/desembarcam,
            do ponto de vista do horário (lógico, não físico).

            Distinção crucial NeTEx vs GTFS:
            - Em GTFS, stops.txt mistura a identidade lógica (stop_id, nome) com
              a localização física (lat, lon) e até o lugar físico (parent_station).
            - Em NeTEx, há separação clara:
              * ScheduledStopPoint = ponto lógico (existe no ServiceFrame)
              * StopPlace/Quay = lugar físico (existe no SiteFrame, ver Módulo 4)
              * PassengerStopAssignment = ligação entre os dois

            Aqui mostramos as paragens principais da Linha 200.
            O Módulo 2 mostrará como ligá-las a uma Route.
          -->
          <scheduledStopPoints>

            <!--
              Paragem: Bolhão (ponto inicial da Linha 200)
              stop_id GTFS: BLRB1
              Coordenadas GTFS: 41.151868, -8.607115
              Zona tarifária GTFS: PRT1
            -->
            <ScheduledStopPoint id="PT:STCP:ScheduledStopPoint:BLRB1:LOC" version="1">
              <Name>Bolhão</Name>
              <!--
                Location: coordenadas do ponto lógico de paragem.
                Nota: em NeTEx, as coordenadas podem estar no ScheduledStopPoint
                (para dados simples) ou no Quay do SiteFrame (para dados detalhados).
                Para o perfil PT-EPIP, as coordenadas devem estar no StopPlace/Quay.
                Aqui incluímos no ScheduledStopPoint para simplicidade do exemplo.
              -->
              <Location>
                <Longitude>-8.607115</Longitude>
                <Latitude>41.151868</Latitude>
              </Location>
            </ScheduledStopPoint>

            <!-- Paragem: Carmo | stop_id GTFS: CMO -->
            <ScheduledStopPoint id="PT:STCP:ScheduledStopPoint:CMO:LOC" version="1">
              <Name>Carmo</Name>
              <Location>
                <Longitude>-8.616926</Longitude>
                <Latitude>41.147223</Latitude>
              </Location>
            </ScheduledStopPoint>

            <!-- Paragem: Praça da Galiza | stop_id GTFS: PRG4 -->
            <ScheduledStopPoint id="PT:STCP:ScheduledStopPoint:PRG4:LOC" version="1">
              <Name>Praça da Galiza</Name>
              <Location>
                <Longitude>-8.627041</Longitude>
                <Latitude>41.152531</Latitude>
              </Location>
            </ScheduledStopPoint>

            <!-- Paragem: Mercado da Foz | stop_id GTFS: MFZ1 -->
            <ScheduledStopPoint id="PT:STCP:ScheduledStopPoint:MFZ1:LOC" version="1">
              <Name>Mercado da Foz</Name>
              <Location>
                <Longitude>-8.673343</Longitude>
                <Latitude>41.155048</Latitude>
              </Location>
            </ScheduledStopPoint>

            <!-- Paragem: Castelo do Queijo (terminal) | stop_id GTFS: CQ10 -->
            <ScheduledStopPoint id="PT:STCP:ScheduledStopPoint:CQ10:LOC" version="1">
              <Name>Castelo do Queijo</Name>
              <Location>
                <Longitude>-8.689127</Longitude>
                <Latitude>41.167422</Latitude>
              </Location>
            </ScheduledStopPoint>

          </scheduledStopPoints>

        </ServiceFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
