<?xml version="1.0" encoding="UTF-8"?>
<!--
  SOLUÇÃO — Exercício 1: Identificadores e Referências NeTEx
  ===========================================================
  Módulo 1 — Conceitos Base

  PARTE A — Identificadores Correctos:
    STCP (Operator)       → PT:STCP:Operator:STCP:LOC
    Linha 201 (Line)      → PT:STCP:Line:201:LOC
    Paragem 0AAL2 (SSP)   → PT:STCP:ScheduledStopPoint:0AAL2:LOC
    Linha 300 (Line)      → PT:STCP:Line:300:LOC
    IMT (Authority)       → PT:IMT:Authority:IMT:LOC
      (nota: o "operador" no ID do Authority é o código da própria autoridade)

  PARTE B — Erros nos Fragmentos:
    Fragmento 1: ID "200" não tem o formato hierárquico.
      Correcto: id="PT:STCP:Line:200:LOC"
    Fragmento 2: lineRef usa "200" em vez do ID completo.
      Correcto: ref="PT:STCP:Line:200:LOC"
    Fragmento 3: Falta o atributo version="1" no Operator.
      Correcto: <Operator id="PT:STCP:Operator:STCP:LOC" version="1">

  PARTE C — ResourceFrame completo (ver abaixo):
-->

<PublicationDelivery
    xmlns="http://www.netex.org.uk/netex"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    version="1.0">

  <PublicationTimestamp>2026-04-30T00:00:00Z</PublicationTimestamp>
  <ParticipantRef>PT:STCP</ParticipantRef>

  <dataObjects>
    <CompositeFrame id="PT:STCP:CompositeFrame:Exercicio01:LOC" version="1">

      <validBetween>
        <!-- FromDate = 2026-04-30 conforme pedido no enunciado -->
        <FromDate>2026-04-30</FromDate>
      </validBetween>

      <frames>

        <!--
          ResourceFrame com Authority (IMT) e Operator (STCP).
          Todos os campos do agency.txt GTFS mapeados para NeTEx.
        -->
        <ResourceFrame id="PT:STCP:ResourceFrame:Exercicio01_RF:LOC" version="1">
          <organisations>

            <!--
              Authority: IMT — entidade reguladora do transporte em Portugal.
              O IMT não está em agency.txt (o GTFS não modela autoridades),
              mas em NeTEx é boa prática incluí-lo para rastreabilidade.
            -->
            <Authority id="PT:IMT:Authority:IMT:LOC" version="1">
              <Name>Instituto da Mobilidade e dos Transportes</Name>
              <ShortName>IMT</ShortName>
              <ContactDetails>
                <Url>https://www.imt-ip.pt</Url>
              </ContactDetails>
            </Authority>

            <!--
              Operator: STCP — mapeia directamente o agency.txt GTFS.

              Mapeamento campo a campo:
                agency_id    → id (PT:STCP:Operator:STCP:LOC)
                agency_name  → Name (nome completo)
                             → ShortName (nome abreviado)
                             → PublicCode (código público)
                agency_url   → ContactDetails/Url
                agency_phone → ContactDetails/Phone
                (agency_timezone e agency_lang são implícitos pelo país PT)
            -->
            <Operator id="PT:STCP:Operator:STCP:LOC" version="1">
              <Name>Sociedade de Transportes Colectivos do Porto, E.I.M., S.A.</Name>
              <ShortName>STCP</ShortName>
              <PublicCode>STCP</PublicCode>
              <ContactDetails>
                <Url>https://www.stcp.pt</Url>
                <!--
                  Phone: mapeado de agency_phone.
                  GTFS: "225071000" → NeTEx: incluir indicativo internacional
                -->
                <Phone>+351225071000</Phone>
              </ContactDetails>
            </Operator>

          </organisations>
        </ResourceFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
